// ============================================ ALERT FUNCTIONS ======================================
// Build chart URL for alerts
getChartUrl() =>
    "https://www.tradingview.com/chart/?symbol=" + syminfo.prefix + ":" + syminfo.ticker + "&interval=5"

// Get current time in IST format
getTimeIST() =>
    str.format_time(time, "HH:mm", "Asia/Kolkata") + " IST"

// Build Entry Alert Message (LONG/SHORT) - Telegram JSON format
buildEntryAlert(bool isLong, float entryPrice, float slPrice, float tpPrice, float tp1_5Price, float tp2Price, float tp3Price, float riskAmt, float rewardAmt) =>
    string direction = isLong ? "LONG" : "SHORT"
    string emoji = isLong ? "🟢" : "🔴"
    float riskVal = math.abs(entryPrice - slPrice)
    float rewardVal = math.abs(tpPrice - entryPrice)
    float rrRatio = riskVal > 0 ? rewardVal / riskVal : 0

    string msg = emoji + " ORB " + direction + " | " + syminfo.ticker + "\\n"
    msg += "------------------------\\n"
    msg += "Entry: " + str.tostring(entryPrice, "#.##") + "\\n"
    msg += "Target: " + str.tostring(tpPrice, "#.##") + "\\n"
    msg += "SL: " + str.tostring(slPrice, "#.##") + "\\n"
    msg += "------------------------\\n"
    msg += "TP1_5: " + str.tostring(tp1_5Price, "#.##") + "\\n"
    msg += "TP2: " + str.tostring(tp2Price, "#.##") + "\\n"
    msg += "TP3: " + str.tostring(tp3Price, "#.##") + "\\n"
    msg += "------------------------\\n"
    msg += "Risk: " + str.tostring(riskVal, "#.##") + " | Reward: " + str.tostring(rewardVal, "#.##") + "\\n"
    msg += "R:R 1:" + str.tostring(rrRatio, "#.#") + "\\n"
    msg += "------------------------\\n"
    msg += getTimeIST() + "\\n"
    msg += getChartUrl()
    '{"chat_id": "' + telegram_chat_id + '", "text": "' + msg + '", "parse_mode": "Markdown"}'

// Build SL Hit Alert Message - Telegram JSON format
buildSLAlert(bool isLong, float entryPrice, float slPrice, float tpPrice, float exitPrice) =>
    string direction = isLong ? "LONG" : "SHORT"
    string emoji = isLong ? "🟢" : "🔴"
    float pnlAmt = isLong ? (exitPrice - entryPrice) : (entryPrice - exitPrice)
    float pnlPct = (pnlAmt / entryPrice) * 100
    float riskVal = math.abs(entryPrice - slPrice)
    float rewardVal = math.abs(tpPrice - entryPrice)
    float rrRatio = riskVal > 0 ? rewardVal / riskVal : 0

    string msg = "❌ SL HIT | " + syminfo.ticker + "\\n"
    msg += "------------------------\\n"
    msg += emoji + " " + direction + " | Entry: " + str.tostring(entryPrice, "#.##") + "\\n"
    msg += "Exit: " + str.tostring(exitPrice, "#.##") + "\\n"
    msg += "------------------------\\n"
    msg += "Loss: " + str.tostring(pnlAmt, "#.##") + " (" + str.tostring(pnlPct, "#.#") + "%)\\n"
    msg += "Risk: " + str.tostring(riskVal, "#.##") + " | Reward: " + str.tostring(rewardVal, "#.##") + "\\n"
    msg += "R:R was 1:" + str.tostring(rrRatio, "#.#") + "\\n"
    msg += "------------------------\\n"
    msg += getTimeIST() + "\\n"
    msg += getChartUrl()
    '{"chat_id": "' + telegram_chat_id + '", "text": "' + msg + '", "parse_mode": "Markdown"}'

// Build TP Hit Alert Message - Telegram JSON format
// exitQtyPct: % of current open position to exit at this TP level (0-100).
// Signal engine reads ExitQtyPct field directly — no tp_levels config needed.
buildTPAlert(bool isLong, float entryPrice, float slPrice, float tpPrice, float exitPrice, string tpLevel, int exitQtyPct) =>
    string direction = isLong ? "LONG" : "SHORT"
    string emoji = isLong ? "🟢" : "🔴"
    float pnlAmt = isLong ? (exitPrice - entryPrice) : (entryPrice - exitPrice)
    float pnlPct = (pnlAmt / entryPrice) * 100
    float riskVal = math.abs(entryPrice - slPrice)
    float rewardVal = math.abs(tpPrice - entryPrice)
    float rrRatio = riskVal > 0 ? rewardVal / riskVal : 0

    string msg = "✅ ORB " + tpLevel + " HIT | " + syminfo.ticker + "\\n"
    msg += "------------------------\\n"
    msg += emoji + " " + direction + " | Entry: " + str.tostring(entryPrice, "#.##") + "\\n"
    msg += "Exit: " + str.tostring(exitPrice, "#.##") + "\\n"
    msg += "------------------------\\n"
    msg += "Profit: +" + str.tostring(pnlAmt, "#.##") + " (+" + str.tostring(pnlPct, "#.#") + "%)\\n"
    msg += "Risk: " + str.tostring(riskVal, "#.##") + " | Reward: " + str.tostring(rewardVal, "#.##") + "\\n"
    msg += "R:R 1:" + str.tostring(rrRatio, "#.#") + "\\n"
    msg += "ExitQtyPct: " + str.tostring(exitQtyPct) + "\\n"
    msg += "------------------------\\n"
    msg += getTimeIST() + "\\n"
    msg += getChartUrl()
    '{"chat_id": "' + telegram_chat_id + '", "text": "' + msg + '", "parse_mode": "Markdown"}'

// Build Time Exit Alert Message (configurable time exit) - Telegram JSON format
buildTimeExitAlert(bool isLong, float entryPrice, float slPrice, float tpPrice, float exitPrice) =>
    string direction = isLong ? "LONG" : "SHORT"
    string emoji = isLong ? "🟢" : "🔴"
    float pnlAmt = isLong ? (exitPrice - entryPrice) : (entryPrice - exitPrice)
    float pnlPct = (pnlAmt / entryPrice) * 100
    float riskVal = math.abs(entryPrice - slPrice)
    float rewardVal = math.abs(tpPrice - entryPrice)
    float rrRatio = riskVal > 0 ? rewardVal / riskVal : 0
    string pnlSign = pnlAmt >= 0 ? "+" : ""

    string msg = "⏰ TIME EXIT | " + syminfo.ticker + "\\n"
    msg += "------------------------\\n"
    msg += emoji + " " + direction + " | Entry: " + str.tostring(entryPrice, "#.##") + "\\n"
    msg += "Exit: " + str.tostring(exitPrice, "#.##") + "\\n"
    msg += "------------------------\\n"
    msg += "P&L: " + pnlSign + str.tostring(pnlAmt, "#.##") + " (" + pnlSign + str.tostring(pnlPct, "#.#") + "%)\\n"
    msg += "Risk: " + str.tostring(riskVal, "#.##") + " | Reward: " + str.tostring(rewardVal, "#.##") + "\\n"
    msg += "R:R was 1:" + str.tostring(rrRatio, "#.#") + "\\n"
    msg += "------------------------\\n"
    msg += getTimeIST() + "\\n"
    msg += getChartUrl()
    '{"chat_id": "' + telegram_chat_id + '", "text": "' + msg + '", "parse_mode": "Markdown"}'

// Build Test Alert Message
buildTestAlert() =>
    string msg = "🧪 TEST ALERT - ORB Strategy\n\n"
    msg += "✅ Webhook connection successful!\n\n"
    msg += "Symbol: " + syminfo.ticker + "\n"
    msg += "Exchange: " + syminfo.prefix + "\n"
