sendTestAlert = input.bool(false, "Send Test Alert", group=grp_telegram, tooltip="Enable to send a test alert message.\n\nSTEPS:\n1. Enable this option\n2. Create alert: 'Any alert() function call'\n3. Webhook: https://api.telegram.org/bot<TOKEN>/sendMessage\n4. Alert triggers on last bar\n5. Disable after testing")
