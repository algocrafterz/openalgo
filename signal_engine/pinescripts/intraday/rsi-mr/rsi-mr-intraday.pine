//@version=6
// RSI(2) Mean Reversion — Intraday v3.1 (NSE 5-min)
// ─────────────────────────────────────────────────────────────────────────────
// Changes from v3 (2026-04-25) — Indian NSE tuning:
//   1. rsiThresh default: 10 → 7
//      (deeper oversold = higher expected bounce per Connors research;
//       7 is a balance between Canonical Connors <5 and permissive <10,
//       favours quality over signal count)
//   2. atrSlMult default: 1.0 → 1.25
//      (v3 default of 1.0× is flagged "SL hunting risk" by the tooltip itself;
//       1.25× widens SL just enough to avoid noise stops while slCapPct=1.5%
//       still caps outsized risk; ATR meaningfully adapts to per-stock volatility)
//   3. Entry window end: 9:44 → 9:59
//      (STRATEGY-ANALYSIS §5.2 identifies 9:30–10:15 as the primary opportunity
//       zone; v3 window cut off at 9:44 — only 4 entry bars. Extending to 9:59
//       gives 7 entry bars (9:25–9:55) covering most of the primary zone while
//       leaving 75 min for VWAP reclaim before 11:15 time exit)
//   4. slippage: 2 → 3 ticks
//      (₹0.15 per share on ₹150–500 NSE stocks; realistic for mid-cap liquidity
//       during opening volatility; 2 ticks was optimistic for non-large-caps)
// ─────────────────────────────────────────────────────────────────────────────
// Changes from v2:
//   1. minRR default: 0.0 → 0.5
//      (v2 default was 0.0 — misaligned with strategy docs; this alone filters the
//       most common bad setups where ATR SL >> VWAP gap, e.g. INDOTHAI 2026-04-15
//       had R:R 0.36 and should have been skipped)
//   2. minVwapGapPct default: 0.20% → 0.50%
//      (at 9:15–9:20, VWAP is only 1–2 bars old and barely deviates from price;
//       a 0.2% gap is noise; 0.5% ensures a meaningful reward target exists)
//   3. Entry window start: 9:15 → 9:25 AM
//      (skip first 2 bars; ATR(10) at 9:15–9:20 spans mostly prior-day data
//       making SL placement unreliable; by 9:25 we have 3 intraday bars)
//   4. SL cap tightened: 2.0% → 1.5%
//      (hard cap now closer to expected ATR range; prevents outsized loss on
//       gap-heavy opens where ATR is still inflated from prior session)
// ─────────────────────────────────────────────────────────────────────────────
// Changes from v1 (carried forward from v2):
//   1. Time exit extended: 10:30 → 11:15 AM
//   2. Momentum filter added: bar low > prev bar low OR close > prev bar high
//   3. Volume multiplier default lowered: 1.2× → 1.0×
// ─────────────────────────────────────────────────────────────────────────────
// Stock selection: Chartink scanner (RSI(2) < threshold, daily).
// Entry: 9:25–9:59 AM, price below VWAP, first qualifying 5-min bar.
// TP: VWAP at entry (fixed). SL: ATR(10)×mult (primary), PDL if lower, capped at cap%.
// Time exit: 11:15 AM. One trade per symbol per session.
// Telegram alerts → Bot API JSON format (observation channel).
// ─────────────────────────────────────────────────────────────────────────────
strategy("intraday-rsi-mr-v3", shorttitle="", overlay=true,
     pyramiding=0,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=10,
     initial_capital=100000,
     currency=currency.INR,
     commission_type=strategy.commission.percent,
     commission_value=0.094,
     slippage=3,
     process_orders_on_close=false,
     calc_on_every_tick=false)

// ═══════════════════════════════════════════════════════════════════════════
// INPUT GROUPS
// ═══════════════════════════════════════════════════════════════════════════
string GRP_DAILY    = "Daily Filter (Chartink)"
string GRP_ENTRY    = "Entry Conditions"
string GRP_RISK     = "Risk / Exit"
string GRP_TELEGRAM = "Telegram Alerts"

// ═══════════════════════════════════════════════════════════════════════════
// DAILY FILTER
// ═══════════════════════════════════════════════════════════════════════════
float rsiThresh = input.float(7.0, "RSI(2) Threshold", minval=2.0, maxval=15.0, step=1.0,
     group=GRP_DAILY,
     tooltip="Match to your Chartink scanner filter.\n\n" +
     "< 5: Canonical Connors (most oversold, fewer signals)\n" +
     "< 7: v3.1 default — quality/count balance for Indian mid-caps\n" +
     "< 10: Permissive (more signals, lower avg quality)\n" +
     "< 15: Very permissive — noisy setups")

bool useTrendFilter = input.bool(true, "Require Close > SMA (Daily)", inline="trend", group=GRP_DAILY,
     tooltip="Only trade stocks above this SMA. Keeps you on the right side of the trend.")
int  trendLen       = input.int(200, "", minval=50, maxval=200, step=50, inline="trend", group=GRP_DAILY,
     tooltip="200: Canonical Connors  100: More signals  50: Most permissive")

// ═══════════════════════════════════════════════════════════════════════════
// ENTRY CONDITIONS
// ═══════════════════════════════════════════════════════════════════════════
float minVwapGapPct = input.float(0.50, "Min Gap to VWAP (%)", minval=0.05, maxval=1.0, step=0.05,
     group=GRP_ENTRY,
     tooltip="Entry must be at least this % below VWAP.\n" +
     "Ensures meaningful room to TP.\n\n" +
     "0.20%: Permissive (early-session VWAP barely deviates — too noisy)\n" +
     "0.50%: Standard (v3 default)\n" +
     "0.75%: Strict (fewer signals, higher average gap quality)")

float minVolMult = input.float(1.0, "Volume Multiplier (× 20-bar avg)", minval=0.5, maxval=3.0, step=0.1,
     group=GRP_ENTRY,
     tooltip="Volume must exceed this multiple of the 20-bar moving average.\n\n" +
     "1.0×: Standard (opening bars have elevated volume — don't over-filter)\n" +
     "1.2×: Moderate  1.5×: High-volume only")

bool requireMomentum = input.bool(true, "Momentum Filter", group=GRP_ENTRY,
     tooltip="Entry bar must show bounce confirmation:\n" +
     "  — Bar low > previous bar low  (higher low = sellers weakening), OR\n" +
     "  — Bar close > previous bar high  (breaks out of prior bar = strength)\n\n" +
     "Skipped on first bar of session (no intraday predecessor).\n" +
     "Reduces falling-knife entries ~30-40%.")

// ═══════════════════════════════════════════════════════════════════════════
// RISK / EXIT
// ═══════════════════════════════════════════════════════════════════════════
float atrSlMult = input.float(1.25, "ATR(10) SL Multiplier", minval=0.5, maxval=3.0, step=0.25,
     group=GRP_RISK,
     tooltip="SL = entry − ATR(10) × multiplier  (adapts to each stock's volatility)\n" +
     "1.0×: Very tight (SL hunting risk)\n" +
     "1.25×: v3.1 default — avoids noise stops, cap still protects high-ATR cases\n" +
     "1.5×: Standard (cap often binds on typical Indian mid-caps)\n" +
     "2.0×: Wide (high-ATR stocks only)\n\n" +
     "ATR adapts automatically: liquid large-caps get a tighter SL, volatile mid-caps get wider.")

float slCapPct = input.float(1.5, "SL Cap (% from entry)", minval=0.5, maxval=5.0, step=0.5,
     group=GRP_RISK,
     tooltip="Hard cap: SL cannot be more than this % below entry.\n" +
     "Acts as a safety net when ATR is large (e.g., volatile session).\n" +
     "Final SL = max(ATR-based SL, PDL), then capped at entry × (1 − cap%).\n\n" +
     "1.5%: Standard (v3 — tighter cap, forces better R:R)\n" +
     "2.0%: Permissive (v2 default)  2.5%: High-ATR stocks")

float minRR = input.float(0.5, "Minimum R:R to Enter", minval=0.0, maxval=3.0, step=0.25,
     group=GRP_RISK,
     tooltip="Skip trades where planned reward/risk < this value.\n" +
     "Mean reversion setups structurally have R:R < 1 (wide ATR SL, small VWAP gap).\n" +
     "0.5 filters the worst setups (wide SL, tiny VWAP gap) while allowing valid MR entries.\n\n" +
     "0.0: Off  0.5: Standard (v3 default)  0.75: Strict  1.0: Very strict")

// ═══════════════════════════════════════════════════════════════════════════
// TELEGRAM ALERTS
// ═══════════════════════════════════════════════════════════════════════════
bool   enableAlerts     = input.bool(true, "Enable Telegram Alerts", group=GRP_TELEGRAM,
     tooltip="ON: Telegram alerts fire for Entry / TP / SL / Time Exit.\n" +
     "OFF: Chart signals only (useful during backtesting).")

string telegram_chat_id = input.string("-1003867620157", "Chat ID", group=GRP_TELEGRAM,
     tooltip="Your Telegram observation channel/group chat ID.\n" +
     "Format: -100xxxxxxxxxx (negative for channels)")

bool   sendTestAlert    = input.bool(false, "Send Test Alert", group=GRP_TELEGRAM,
     tooltip="Enable, then create TradingView alert with 'Any alert() function call'.\n" +
     "Fires a test message to verify webhook connectivity.")

string testAlertType    = input.string("Entry", "Test Alert Type",
     options=["Entry", "TP Hit", "SL Hit", "Time Exit"],
     group=GRP_TELEGRAM)

// ═══════════════════════════════════════════════════════════════════════════
// DAILY CONTEXT — [1] offset = previous confirmed bar, no lookahead
// ═══════════════════════════════════════════════════════════════════════════
d_rsi2 = request.security(syminfo.tickerid, "D", ta.rsi(close, 2)[1])
d_sma  = request.security(syminfo.tickerid, "D", ta.sma(close, trendLen))
d_pdl  = request.security(syminfo.tickerid, "D", low[1])
d_pdh  = request.security(syminfo.tickerid, "D", high[1])
d_pdc  = request.security(syminfo.tickerid, "D", close[1])

// ═══════════════════════════════════════════════════════════════════════════
// INTRADAY INDICATORS
// ═══════════════════════════════════════════════════════════════════════════
session_vwap = ta.vwap(hlc3)
vol_ma       = ta.sma(volume, 20)
atr_10       = ta.atr(10)

// ═══════════════════════════════════════════════════════════════════════════
// TIME UTILITIES (IST)
// ═══════════════════════════════════════════════════════════════════════════
_hhmm() =>
    hour(time, "Asia/Kolkata") * 60 + minute(time, "Asia/Kolkata")

int cur = _hhmm()

int T_ENTRY_START = 9 * 60 + 25   // 9:25 AM — skip first 2 bars (VWAP/ATR unreliable before 3 bars)
int T_ENTRY_END   = 9 * 60 + 59   // 9:59 AM — last qualifying bar starts 9:55 (v3.1: extends into primary 9:30-10:15 zone)
int T_TIME_EXIT   = 11 * 60 + 10  // 11:10 AM bar (closes 11:15) — v2: was 10:25

bool in_entry_window = cur >= T_ENTRY_START and cur <= T_ENTRY_END
bool at_time_exit    = cur >= T_TIME_EXIT and cur <= T_TIME_EXIT + 4

getTimeIST() =>
    str.format_time(time, "HH:mm", "Asia/Kolkata") + " IST"

getChartUrl() =>
    "https://www.tradingview.com/chart/?symbol=" + syminfo.prefix + ":" + syminfo.ticker + "&interval=5"

// ═══════════════════════════════════════════════════════════════════════════
// ALERT BUILDERS
// ═══════════════════════════════════════════════════════════════════════════

buildEntryAlert(float entryPrice, float slPrice, float tpPrice, float rr, float gap) =>
    float riskAmt   = entryPrice - slPrice
    float rewardAmt = tpPrice - entryPrice
    string msg = "RSI-MR LONG | " + syminfo.prefix + ":" + syminfo.ticker + "\\n"
    msg += "------------------------\\n"
    msg += "Entry: "      + str.tostring(entryPrice, "#.##") + "\\n"
    msg += "TP (VWAP): "  + str.tostring(tpPrice,    "#.##") + "\\n"
    msg += "SL: "         + str.tostring(slPrice,     "#.##") + "\\n"
    msg += "------------------------\\n"
    msg += "Risk: "       + str.tostring(riskAmt,   "#.##") +
           " | Reward: "  + str.tostring(rewardAmt, "#.##") + "\\n"
    msg += "R:R 1:"       + str.tostring(rr,  "#.1") +
           " | Gap: "     + str.tostring(gap, "#.2") + "%\\n"
    msg += "RSI(2): "     + str.tostring(d_rsi2, "#.##") + "\\n"
    msg += "------------------------\\n"
    msg += getTimeIST() + "\\n"
    msg += getChartUrl()
    '{"chat_id": "' + telegram_chat_id + '", "text": "' + msg + '", "parse_mode": "Markdown"}'

buildTPAlert(float entryPrice, float slPrice, float tpPrice, float exitPrice) =>
    float pnlAmt = exitPrice - entryPrice
    float pnlPct = pnlAmt / entryPrice * 100
    float rr     = math.abs(tpPrice - entryPrice) / math.abs(entryPrice - slPrice)
    string msg = "TP HIT (VWAP) | " + syminfo.prefix + ":" + syminfo.ticker + "\\n"
    msg += "------------------------\\n"
    msg += "LONG | Entry: " + str.tostring(entryPrice, "#.##") + "\\n"
    msg += "Exit: "          + str.tostring(exitPrice,  "#.##") + "\\n"
    msg += "------------------------\\n"
    msg += "Profit: +"       + str.tostring(pnlAmt, "#.##") +
           " (+"             + str.tostring(pnlPct, "#.1") + "%)\\n"
    msg += "R:R 1:"          + str.tostring(rr, "#.1") + "\\n"
    msg += "------------------------\\n"
    msg += getTimeIST() + "\\n"
    msg += getChartUrl()
    '{"chat_id": "' + telegram_chat_id + '", "text": "' + msg + '", "parse_mode": "Markdown"}'

buildSLAlert(float entryPrice, float slPrice, float tpPrice, float exitPrice) =>
    float pnlAmt = exitPrice - entryPrice
    float pnlPct = pnlAmt / entryPrice * 100
    float rr     = math.abs(tpPrice - entryPrice) / math.abs(entryPrice - slPrice)
    string msg = "SL HIT | " + syminfo.prefix + ":" + syminfo.ticker + "\\n"
    msg += "------------------------\\n"
    msg += "LONG | Entry: " + str.tostring(entryPrice, "#.##") + "\\n"
    msg += "Exit: "          + str.tostring(exitPrice,  "#.##") + "\\n"
    msg += "------------------------\\n"
    msg += "Loss: "          + str.tostring(pnlAmt, "#.##") +
           " ("              + str.tostring(pnlPct, "#.1") + "%)\\n"
    msg += "R:R was 1:"      + str.tostring(rr, "#.1") + "\\n"
    msg += "------------------------\\n"
    msg += getTimeIST() + "\\n"
    msg += getChartUrl()
    '{"chat_id": "' + telegram_chat_id + '", "text": "' + msg + '", "parse_mode": "Markdown"}'

buildTimeExitAlert(float entryPrice, float slPrice, float tpPrice, float exitPrice) =>
    float pnlAmt   = exitPrice - entryPrice
    float pnlPct   = pnlAmt / entryPrice * 100
    string pnlSign = pnlAmt >= 0 ? "+" : ""
    float rr       = math.abs(tpPrice - entryPrice) / math.abs(entryPrice - slPrice)
    string msg = "TIME EXIT 11:15 | " + syminfo.prefix + ":" + syminfo.ticker + "\\n"
    msg += "------------------------\\n"
    msg += "LONG | Entry: " + str.tostring(entryPrice, "#.##") + "\\n"
    msg += "Exit: "          + str.tostring(exitPrice,  "#.##") + "\\n"
    msg += "------------------------\\n"
    msg += "P&L: "           + pnlSign + str.tostring(pnlAmt, "#.##") +
           " ("              + pnlSign + str.tostring(pnlPct, "#.1") + "%)\\n"
    msg += "R:R was 1:"      + str.tostring(rr, "#.1") + "\\n"
    msg += "------------------------\\n"
    msg += getTimeIST() + "\\n"
    msg += getChartUrl()
    '{"chat_id": "' + telegram_chat_id + '", "text": "' + msg + '", "parse_mode": "Markdown"}'

buildTestAlert() =>
    string msg = "TEST ALERT — RSI-MR Strategy\\n\\n"
    msg += "Webhook connection successful!\\n\\n"
    msg += "Symbol: "   + syminfo.ticker + "\\n"
    msg += "Exchange: " + syminfo.prefix + "\\n"
    msg += "Price: "    + str.tostring(close, "#.##") + "\\n"
    msg += "RSI(2): "   + str.tostring(d_rsi2, "#.##") + "\\n"
    msg += "VWAP: "     + str.tostring(session_vwap, "#.##") + "\\n"
    msg += "Time: "     + getTimeIST() + "\\n\\n"
    msg += "Preview (" + testAlertType + "):\\n"
    if testAlertType == "Entry"
        msg += "Entry=" + str.tostring(close, "#.##") +
               " SL=" + str.tostring(close * 0.98, "#.##") +
               " TP=" + str.tostring(session_vwap, "#.##") + "\\n"
    else if testAlertType == "TP Hit"
        msg += "TP (VWAP) hit at " + str.tostring(session_vwap, "#.##") + "\\n"
    else if testAlertType == "SL Hit"
        msg += "SL hit at " + str.tostring(close * 0.98, "#.##") + "\\n"
    else
        msg += "Time exit at " + str.tostring(close, "#.##") + "\\n"
    msg += "\\nChart: " + getChartUrl()
    '{"chat_id": "' + telegram_chat_id + '", "text": "' + msg + '", "parse_mode": "Markdown"}'

// ═══════════════════════════════════════════════════════════════════════════
// ENTRY CONDITIONS
// ═══════════════════════════════════════════════════════════════════════════
float vwap_gap_pct = na(session_vwap) ? na : (session_vwap - close) / close * 100

// Daily conditions
bool c_rsi    = not na(d_rsi2) and d_rsi2 < rsiThresh
bool c_trend  = not useTrendFilter or (not na(d_sma) and close > d_sma)

// Intraday VWAP conditions
bool c_vwap_pos = not na(session_vwap) and close < session_vwap
bool c_vwap_gap = not na(vwap_gap_pct) and vwap_gap_pct >= minVwapGapPct

// Bar pattern
bool c_bullish = close > open

// Structural
bool c_pdl    = not na(d_pdl) and close > d_pdl

// Volume
bool c_volume = volume >= minVolMult * vol_ma

// Momentum (v2): higher low OR breaks prior bar high
// Skip on first bar of session — no intraday predecessor exists
bool is_first_session_bar = ta.change(dayofmonth) != 0
bool c_momentum = not requireMomentum or is_first_session_bar or
     (low > low[1] or close > high[1])

// Prospective SL/TP for R:R pre-check
// ATR-based SL (primary): adapts to each stock's intraday volatility.
// PDL override: if PDL is BELOW the ATR SL (further from entry), use PDL as the structural stop.
// Hard cap: SL cannot be more than slCapPct% below entry (prevents outsized risk on gappy opens).
float sl_atr_base  = close - atr_10 * atrSlMult
float prosp_sl_raw = not na(d_pdl) and d_pdl < sl_atr_base ? d_pdl : sl_atr_base
float prosp_sl     = math.max(prosp_sl_raw, close * (1.0 - slCapPct / 100.0))
float prosp_tp = session_vwap
float prosp_rr = na(prosp_tp) or na(prosp_sl) or prosp_sl >= close ?
     0.0 : (prosp_tp - close) / (close - prosp_sl)
bool c_rr = prosp_rr >= minRR

// c_bullish removed: momentum filter already confirms reversal (higher low OR outside bar close).
// Requiring a green bar on an oversold open eliminates valid setups where selling exhausts
// in the first 1-2 bars before the bounce begins.
bool all_entry = c_rsi and c_trend and c_vwap_pos and c_vwap_gap and
     c_pdl and c_volume and c_momentum and c_rr

// ═══════════════════════════════════════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════════════════════════════════════
var bool  in_trade  = false
var bool  day_fired = false
var float entry_px  = na
var float sl_px     = na
var float tp_px     = na

bool new_day = ta.change(dayofmonth) != 0
if new_day
    in_trade  := false
    day_fired := false

// ═══════════════════════════════════════════════════════════════════════════
// ENTRY
// ═══════════════════════════════════════════════════════════════════════════
// barstate.isconfirmed not needed in strategy — calc_on_every_tick=false ensures bar-close evaluation
bool entry_signal = in_entry_window and not day_fired and all_entry

if entry_signal
    entry_px        := close
    float _sl_atr   = close - atr_10 * atrSlMult
    float _sl_raw   = not na(d_pdl) and d_pdl < _sl_atr ? d_pdl : _sl_atr
    sl_px           := math.max(_sl_raw, close * (1.0 - slCapPct / 100.0))
    tp_px           := session_vwap
    in_trade  := true
    day_fired := true

    float rr = (tp_px - entry_px) / (entry_px - sl_px)

    strategy.entry("Long", strategy.long)
    strategy.exit("TP/SL", "Long", limit=tp_px, stop=sl_px)

    if enableAlerts
        alert(buildEntryAlert(entry_px, sl_px, tp_px, rr, vwap_gap_pct), alert.freq_once_per_bar_close)

// ═══════════════════════════════════════════════════════════════════════════
// SL HIT
// ═══════════════════════════════════════════════════════════════════════════
bool sl_hit = in_trade and low <= sl_px

if sl_hit
    in_trade := false
    // strategy.exit("TP/SL") already closes the position; only alert here
    if enableAlerts
        alert(buildSLAlert(entry_px, sl_px, tp_px, sl_px), alert.freq_once_per_bar_close)

// ═══════════════════════════════════════════════════════════════════════════
// TP HIT
// ═══════════════════════════════════════════════════════════════════════════
bool tp_hit = in_trade and close >= tp_px

if tp_hit
    in_trade := false
    // strategy.exit("TP/SL") already closes the position; only alert here
    if enableAlerts
        alert(buildTPAlert(entry_px, sl_px, tp_px, tp_px), alert.freq_once_per_bar_close)

// ═══════════════════════════════════════════════════════════════════════════
// TIME EXIT — 11:15 AM (v2: extended from 10:30)
// ═══════════════════════════════════════════════════════════════════════════
bool time_exit_signal = in_trade and at_time_exit

if time_exit_signal
    in_trade := false
    strategy.close("Long", comment="Time Exit 11:15")

    if enableAlerts
        alert(buildTimeExitAlert(entry_px, sl_px, tp_px, close), alert.freq_once_per_bar_close)

// ═══════════════════════════════════════════════════════════════════════════
// TEST ALERT
// ═══════════════════════════════════════════════════════════════════════════
if sendTestAlert and barstate.islastconfirmedhistory
    alert(buildTestAlert(), alert.freq_once_per_bar_close)

// ═══════════════════════════════════════════════════════════════════════════
// VISUALS — Chart background, markers, reference lines
// ═══════════════════════════════════════════════════════════════════════════
bgcolor(in_entry_window ? color.new(color.yellow, 93) : na, title="Entry Window 9:25-9:59")

plotshape(entry_signal,
     title="Entry", style=shape.triangleup, location=location.belowbar,
     color=color.new(color.lime, 0), size=size.normal)

plotshape(tp_hit,
     title="TP Hit", style=shape.circle, location=location.abovebar,
     color=color.new(color.lime, 0), size=size.small)

plotshape(sl_hit,
     title="SL Hit", style=shape.xcross, location=location.belowbar,
     color=color.new(color.red, 0), size=size.small)

plotshape(time_exit_signal,
     title="Time Exit", style=shape.xcross, location=location.abovebar,
     color=color.new(color.orange, 0), size=size.small)

plot(session_vwap, title="VWAP",
     color=color.new(color.blue, 20), linewidth=2)

plot(d_pdl, title="PDL",
     color=color.new(color.red,    50), linewidth=1, style=plot.style_stepline)
plot(d_pdh, title="PDH",
     color=color.new(color.green,  50), linewidth=1, style=plot.style_stepline)
plot(d_pdc, title="PDC",
     color=color.new(color.orange, 50), linewidth=1, style=plot.style_stepline)

// ═══════════════════════════════════════════════════════════════════════════
// ENTRY / SL / TP LEVEL LINES + LABELS
// Lines are created at entry and extend right while trade is open.
// Labels show price + distance % so trader can relate to current price.
// ═══════════════════════════════════════════════════════════════════════════
var line  ln_entry = na
var line  ln_sl    = na
var line  ln_tp    = na
var label lb_entry = na
var label lb_sl    = na
var label lb_tp    = na

if entry_signal
    // Clear previous trade's levels (keeps chart clean between signals)
    if not na(ln_entry)
        line.delete(ln_entry)
    if not na(ln_sl)
        line.delete(ln_sl)
    if not na(ln_tp)
        line.delete(ln_tp)
    if not na(lb_entry)
        label.delete(lb_entry)
    if not na(lb_sl)
        label.delete(lb_sl)
    if not na(lb_tp)
        label.delete(lb_tp)

    float _sl_pct = (entry_px - sl_px) / entry_px * 100
    float _tp_pct = (tp_px - entry_px) / entry_px * 100
    float _rr     = _tp_pct / _sl_pct

    ln_entry := line.new(bar_index, entry_px, bar_index + 1, entry_px,
         color=color.new(color.lime, 0), width=1, style=line.style_solid)
    ln_sl := line.new(bar_index, sl_px, bar_index + 1, sl_px,
         color=color.new(color.red, 10), width=1, style=line.style_dashed)
    ln_tp := line.new(bar_index, tp_px, bar_index + 1, tp_px,
         color=color.new(color.teal, 10), width=1, style=line.style_dashed)

    lb_entry := label.new(bar_index + 1, entry_px,
         "ENTRY  " + str.tostring(entry_px, "#.##"),
         color=color.new(color.lime, 20), textcolor=color.black,
         style=label.style_label_left, size=size.small)
    lb_sl := label.new(bar_index + 1, sl_px,
         "SL  " + str.tostring(sl_px, "#.##") +
         "  -" + str.tostring(_sl_pct, "#.1") + "%",
         color=color.new(color.red, 10), textcolor=color.white,
         style=label.style_label_left, size=size.small)
    lb_tp := label.new(bar_index + 1, tp_px,
         "TP (VWAP)  " + str.tostring(tp_px, "#.##") +
         "  +" + str.tostring(_tp_pct, "#.1") + "%  R:R " + str.tostring(_rr, "#.1"),
         color=color.new(color.teal, 10), textcolor=color.white,
         style=label.style_label_left, size=size.small)

// Extend lines and labels to the current bar while trade is open
if in_trade and not na(ln_entry)
    line.set_x2(ln_entry, bar_index + 1)
    line.set_x2(ln_sl,    bar_index + 1)
    line.set_x2(ln_tp,    bar_index + 1)
    label.set_x(lb_entry, bar_index + 1)
    label.set_x(lb_sl,    bar_index + 1)
    label.set_x(lb_tp,    bar_index + 1)

// ═══════════════════════════════════════════════════════════════════════════
// UNIFIED DASHBOARD (top right) — single table, three sections
// Timeframe: NSE 5-min chart (IST).  Use "5" in TradingView chart settings.
// ═══════════════════════════════════════════════════════════════════════════
var table dash = table.new(position.top_right, 2, 23,
     bgcolor=color.new(color.black, 80), border_width=1,
     border_color=color.new(color.gray, 70))

if barstate.islastconfirmedhistory or barstate.isrealtime
    string SZ  = size.normal
    string SZT = size.small
    color  GRY = color.gray
    color  WHT = color.white
    color  LIM = color.lime
    color  RED = color.red
    color  ORG = color.orange
    color  TEL = color.teal
    color  NAV = color.new(color.navy, 40)

    // ── HEADER ──────────────────────────────────────────────────
    string alert_txt = enableAlerts ? "ALERTS ON" : "CHART ONLY"
    color  alert_col = enableAlerts ? LIM : color.yellow
    table.cell(dash, 0, 0, "RSI-MR  5-min NSE",
         text_color=WHT, text_size=SZ, bgcolor=NAV, text_halign=text.align_left)
    table.cell(dash, 1, 0, alert_txt,
         text_color=alert_col, text_size=SZ, bgcolor=NAV, text_halign=text.align_right)

    // ── SECTION: DAILY FILTERS ───────────────────────────────────
    bool filters_ok = c_rsi and c_trend and c_pdl and c_volume
    color fhdr_col = filters_ok ? TEL : ORG
    table.cell(dash, 0, 1, "── Filters",
         text_color=fhdr_col, text_size=SZT, text_halign=text.align_left)
    table.cell(dash, 1, 1, filters_ok ? "All pass" : "Blocking",
         text_color=fhdr_col, text_size=SZT, text_halign=text.align_right)

    // RSI(2)
    string rsi_val = not na(d_rsi2) ? str.tostring(d_rsi2, "#.#") + " < " + str.tostring(rsiThresh, "#") : "N/A"
    table.cell(dash, 0, 2, "RSI(2)",
         text_color=GRY, text_size=SZT, text_halign=text.align_left)
    table.cell(dash, 1, 2, (c_rsi ? "✅ " : "❌ ") + rsi_val,
         text_color=c_rsi ? LIM : RED, text_size=SZT, text_halign=text.align_right)

    // Trend
    string trend_val = not na(d_sma) ? ">" + str.tostring(trendLen) + " SMA " + str.tostring(d_sma, "#.#") : "N/A"
    table.cell(dash, 0, 3, "Trend",
         text_color=GRY, text_size=SZT, text_halign=text.align_left)
    table.cell(dash, 1, 3, (c_trend ? "✅ " : "❌ ") + trend_val,
         text_color=c_trend ? LIM : RED, text_size=SZT, text_halign=text.align_right)

    // PDL
    string pdl_val = not na(d_pdl) ? "Hold " + str.tostring(d_pdl, "#.##") : "N/A"
    table.cell(dash, 0, 4, "PDL",
         text_color=GRY, text_size=SZT, text_halign=text.align_left)
    table.cell(dash, 1, 4, (c_pdl ? "✅ " : "❌ ") + pdl_val,
         text_color=c_pdl ? LIM : RED, text_size=SZT, text_halign=text.align_right)

    // Volume
    float cur_vol_mult = vol_ma > 0 ? volume / vol_ma : na
    string vol_val = not na(cur_vol_mult) ? str.tostring(cur_vol_mult, "#.1") + "x avg" : "N/A"
    table.cell(dash, 0, 5, "Volume",
         text_color=GRY, text_size=SZT, text_halign=text.align_left)
    table.cell(dash, 1, 5, (c_volume ? "✅ " : "❌ ") + vol_val,
         text_color=c_volume ? LIM : ORG, text_size=SZT, text_halign=text.align_right)

    // ── SECTION: ENTRY CONDITIONS ────────────────────────────────
    bool entry_ok = c_vwap_gap and c_momentum and c_rr
    color ehdr_col = day_fired ? GRY : (entry_ok and filters_ok ? TEL : ORG)
    table.cell(dash, 0, 6, "── Entry  9:25–9:59",
         text_color=ehdr_col, text_size=SZT, text_halign=text.align_left)
    string win_status = day_fired ? "Done" : in_entry_window ? "Open" : cur < T_ENTRY_START ? "Waiting" : "Closed"
    table.cell(dash, 1, 6, win_status,
         text_color=in_entry_window ? LIM : GRY, text_size=SZT, text_halign=text.align_right)

    // VWAP + gap
    string vwap_str = not na(session_vwap) ? str.tostring(session_vwap, "#.##") : "N/A"
    string gap_str  = not na(vwap_gap_pct) ? str.tostring(vwap_gap_pct, "#.##") + "% gap" : "N/A"
    table.cell(dash, 0, 7, "VWAP",
         text_color=GRY, text_size=SZT, text_halign=text.align_left)
    table.cell(dash, 1, 7, vwap_str + "  " + (c_vwap_gap ? "✅ " : "❌ ") + gap_str,
         text_color=c_vwap_gap ? LIM : ORG, text_size=SZT, text_halign=text.align_right)

    // Momentum
    string mom_str = c_momentum ? "Higher low / outside bar" : "Falling knife"
    table.cell(dash, 0, 8, "Momentum",
         text_color=GRY, text_size=SZT, text_halign=text.align_left)
    table.cell(dash, 1, 8, (c_momentum ? "✅ " : "❌ ") + mom_str,
         text_color=c_momentum ? LIM : ORG, text_size=SZT, text_halign=text.align_right)

    // Prospective R:R
    string rr_str = not na(prosp_rr) ? str.tostring(prosp_rr, "#.##") : "N/A"
    table.cell(dash, 0, 9, "R:R",
         text_color=GRY, text_size=SZT, text_halign=text.align_left)
    table.cell(dash, 1, 9, (c_rr ? "✅ " : "❌ ") + rr_str + " (min " + str.tostring(minRR, "#.#") + ")",
         text_color=c_rr ? LIM : ORG, text_size=SZT, text_halign=text.align_right)

    // Bar colour — info only, not a blocking condition (momentum filter covers direction)
    table.cell(dash, 0, 10, "Bar",
         text_color=GRY, text_size=SZT, text_halign=text.align_left)
    table.cell(dash, 1, 10, c_bullish ? "Green" : "Red  (ok if momentum pass)",
         text_color=c_bullish ? LIM : GRY, text_size=SZT, text_halign=text.align_right)

    // ── SECTION: ACTIVE TRADE / RESULT ───────────────────────────
    if in_trade
        float rr_live = (tp_px - entry_px) / (entry_px - sl_px)
        float _upnl_pct = (close - entry_px) / entry_px * 100
        color trade_col = _upnl_pct >= 0 ? LIM : RED
        table.cell(dash, 0, 11, "── Active Trade",
             text_color=TEL, text_size=SZT, text_halign=text.align_left)
        table.cell(dash, 1, 11, (close >= entry_px ? "+" : "") + str.tostring(_upnl_pct, "#.1") + "%",
             text_color=trade_col, text_size=SZT, text_halign=text.align_right)
        table.cell(dash, 0, 12, "Entry",
             text_color=GRY, text_size=SZT, text_halign=text.align_left)
        table.cell(dash, 1, 12, str.tostring(entry_px, "#.##"),
             text_color=LIM, text_size=SZT, text_halign=text.align_right)
        table.cell(dash, 0, 13, "SL  (ATRx" + str.tostring(atrSlMult, "#.##") + ")",
             text_color=GRY, text_size=SZT, text_halign=text.align_left)
        float _sl_dist = (entry_px - sl_px) / entry_px * 100
        table.cell(dash, 1, 13, str.tostring(sl_px, "#.##") +
             "  -" + str.tostring(_sl_dist, "#.1") + "%",
             text_color=RED, text_size=SZT, text_halign=text.align_right)
        table.cell(dash, 0, 14, "TP  (VWAP)",
             text_color=GRY, text_size=SZT, text_halign=text.align_left)
        float _tp_dist = (tp_px - entry_px) / entry_px * 100
        table.cell(dash, 1, 14, str.tostring(tp_px, "#.##") +
             "  +" + str.tostring(_tp_dist, "#.1") + "%",
             text_color=TEL, text_size=SZT, text_halign=text.align_right)
        table.cell(dash, 0, 15, "R:R",
             text_color=GRY, text_size=SZT, text_halign=text.align_left)
        table.cell(dash, 1, 15, str.tostring(rr_live, "#.##"),
             text_color=rr_live >= 1.0 ? LIM : ORG, text_size=SZT, text_halign=text.align_right)
    else if day_fired
        table.cell(dash, 0, 11, "── Trade Done",
             text_color=GRY, text_size=SZT, text_halign=text.align_left)
        table.cell(dash, 1, 11, "1/1 today",
             text_color=GRY, text_size=SZT, text_halign=text.align_right)
        table.cell(dash, 0, 12, "",  text_color=GRY, text_size=SZT)
        table.cell(dash, 1, 12, "",  text_color=GRY, text_size=SZT)
        table.cell(dash, 0, 13, "",  text_color=GRY, text_size=SZT)
        table.cell(dash, 1, 13, "",  text_color=GRY, text_size=SZT)
        table.cell(dash, 0, 14, "",  text_color=GRY, text_size=SZT)
        table.cell(dash, 1, 14, "",  text_color=GRY, text_size=SZT)
        table.cell(dash, 0, 15, "",  text_color=GRY, text_size=SZT)
        table.cell(dash, 1, 15, "",  text_color=GRY, text_size=SZT)
    else
        bool ready = filters_ok and entry_ok and in_entry_window
        table.cell(dash, 0, 11, "── Signal",
             text_color=ready ? TEL : GRY, text_size=SZT, text_halign=text.align_left)
        table.cell(dash, 1, 11, ready ? "READY" : "Waiting",
             text_color=ready ? LIM : GRY, text_size=SZT, text_halign=text.align_right)
        table.cell(dash, 0, 12, "Prosp SL",
             text_color=GRY, text_size=SZT, text_halign=text.align_left)
        float _psl_pct = not na(prosp_sl) ? (close - prosp_sl) / close * 100 : na
        table.cell(dash, 1, 12, not na(prosp_sl) ?
             str.tostring(prosp_sl, "#.##") + "  -" + str.tostring(_psl_pct, "#.1") + "%" : "--",
             text_color=GRY, text_size=SZT, text_halign=text.align_right)
        table.cell(dash, 0, 13, "Prosp TP",
             text_color=GRY, text_size=SZT, text_halign=text.align_left)
        float _ptp_pct = not na(session_vwap) ? (session_vwap - close) / close * 100 : na
        table.cell(dash, 1, 13, not na(session_vwap) ?
             str.tostring(session_vwap, "#.##") + "  +" + str.tostring(_ptp_pct, "#.1") + "%" : "--",
             text_color=GRY, text_size=SZT, text_halign=text.align_right)
        table.cell(dash, 0, 14, "",  text_color=GRY, text_size=SZT)
        table.cell(dash, 1, 14, "",  text_color=GRY, text_size=SZT)
        table.cell(dash, 0, 15, "",  text_color=GRY, text_size=SZT)
        table.cell(dash, 1, 15, "",  text_color=GRY, text_size=SZT)

    // ── SECTION: PERFORMANCE ─────────────────────────────────────
    int   total  = strategy.closedtrades
    int   wins   = strategy.wintrades
    float wr     = total > 0 ? wins / total * 100 : 0.0
    float gp     = strategy.grossprofit
    float gl     = math.abs(strategy.grossloss)
    float pf     = gl > 0 ? gp / gl : 0.0
    float net    = strategy.netprofit
    float netPct = strategy.initial_capital > 0 ? net / strategy.initial_capital * 100 : 0.0
    float avgT   = total > 0 ? net / total : 0.0
    float maxDD  = strategy.max_drawdown

    table.cell(dash, 0, 16, "── Performance",
         text_color=net >= 0 ? TEL : ORG, text_size=SZT, text_halign=text.align_left)
    table.cell(dash, 1, 16, str.tostring(total) + " trades",
         text_color=GRY, text_size=SZT, text_halign=text.align_right)

    table.cell(dash, 0, 17, "Win Rate",
         text_color=GRY, text_size=SZT, text_halign=text.align_left)
    table.cell(dash, 1, 17, str.tostring(wins) + "W / " + str.tostring(total - wins) + "L  " +
         str.tostring(wr, "#.1") + "%",
         text_color=wr >= 55 ? LIM : ORG, text_size=SZT, text_halign=text.align_right)

    table.cell(dash, 0, 18, "Profit Factor",
         text_color=GRY, text_size=SZT, text_halign=text.align_left)
    table.cell(dash, 1, 18, str.tostring(pf, "#.##"),
         text_color=pf >= 1.5 ? LIM : ORG, text_size=SZT, text_halign=text.align_right)

    table.cell(dash, 0, 19, "Avg Trade",
         text_color=GRY, text_size=SZT, text_halign=text.align_left)
    table.cell(dash, 1, 19, (avgT >= 0 ? "+" : "") + str.tostring(avgT, "#.##"),
         text_color=avgT >= 0 ? LIM : RED, text_size=SZT, text_halign=text.align_right)

    table.cell(dash, 0, 20, "Net P&L",
         text_color=GRY, text_size=SZT, text_halign=text.align_left)
    table.cell(dash, 1, 20, (net >= 0 ? "+" : "") + str.tostring(net, "#") +
         "  (" + (netPct >= 0 ? "+" : "") + str.tostring(netPct, "#.1") + "%)",
         text_color=net >= 0 ? LIM : RED, text_size=SZT, text_halign=text.align_right)

    table.cell(dash, 0, 21, "Max DD",
         text_color=GRY, text_size=SZT, text_halign=text.align_left)
    table.cell(dash, 1, 21, "-" + str.tostring(maxDD, "#"),
         text_color=RED, text_size=SZT, text_halign=text.align_right)

    table.cell(dash, 0, 22, "",  text_color=GRY, text_size=SZT)
    table.cell(dash, 1, 22, "",  text_color=GRY, text_size=SZT)
